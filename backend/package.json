{
  "name": "nukkad-beats-backend",
  "version": "1.0.0",
  "description": "Production-ready REST API backend for NUKKAD BEATS - studio booking and café ordering platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:test": "cross-env DATABASE_URL=\"mysql://root:root@localhost:3306/nukkad_beats_test\" PORT=5001 ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:test": "cross-env DATABASE_URL=\"mysql://root:root@localhost:3306/nukkad_beats_test\" prisma db push --skip-generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:test": "cross-env DATABASE_URL=\"mysql://root:root@localhost:3306/nukkad_beats_test\" ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "express",
    "typescript",
    "prisma",
    "studio-booking",
    "cafe-ordering",
    "rest-api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.5.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.4.11",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-slow-down": "^3.1.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.0.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.4",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
