{
  "openapi": "3.0.0",
  "info": {
    "title": "NUKKAD BEATS API",
    "version": "1.0.0",
    "description": "API documentation for NUKKAD BEATS studio booking and café ordering platform"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Check API health",
        "responses": {
          "200": {
            "description": "API is running"
          }
        }
      }
    }
  }
}
